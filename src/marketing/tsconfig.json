{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"allowJs": true,
		"incremental": true,
		"noEmit": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["../*"],
			"@core/*": ["../core/*"],
			"@server/*": ["../server/*"],
			"@app/*": ["../app/*"],
			"@marketing/*": ["./*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules"]
}
