{
  "name": "coding-assistant",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev:server": "AUTH_SECRET=dev-token bun run --watch apps/server/index.ts",
    "dev:desktop": "cd apps/desktop && bunx vite",
    "dev": "bun run dev:server & bun run dev:desktop",
    "build:server": "bun build apps/server/src/index.ts --outdir dist/server --target bun",
    "build:desktop": "cd apps/desktop && bunx vite build",
    "tauri:dev": "cd apps/desktop/src-tauri && cargo tauri dev",
    "tauri:build": "cd apps/desktop/src-tauri && cargo tauri build",
    "tauri:icons": "cd apps/desktop/src-tauri && cargo tauri icon",
    "test": "bun test",
    "test:persistence": "bun test packages/persistence",
    "test:server": "bun test apps/server",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist node_modules"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^1.1.0",
    "@ai-sdk/google": "^1.1.0",
    "@ai-sdk/openai": "^1.1.0",
    "@hono/node-server": "^1.13.0",
    "@openai/apps-sdk-ui": "^0.2.1",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "ai": "^4.1.0",
    "chokidar": "^4.0.0",
    "hono": "^4.6.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/bun": "^1.1.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "vite": "^6.0.0",
    "tailwindcss": "^4.0.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.2.0"
  }
}
