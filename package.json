{
  "name": "loop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun run --hot src/server/index.ts",
    "dev:app": "vite dev",
    "dev:electron": "node electron/scripts/dev-electron.mjs",
    "build": "vite build",
    "build:electron": "tsdown --config electron/tsdown.config.ts",
    "lint": "biome check src/",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p electron/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "bun run build && bun run build:electron && electron-builder --dir",
    "dist": "bun run build && bun run build:electron && electron-builder",
    "dist:mac": "bun run build && bun run build:electron && electron-builder --mac",
    "dist:win": "bun run build && bun run build:electron && electron-builder --win",
    "dist:linux": "bun run build && bun run build:electron && electron-builder --linux",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/cohere": "^3.0.25",
    "@ai-sdk/deepinfra": "^2.0.39",
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/perplexity": "^3.0.23",
    "@ai-sdk/togetherai": "^2.0.39",
    "@ai-sdk/xai": "^3.0.67",
    "@heroui/react": "^3.0.0-beta.8",
    "@heroui/styles": "^3.0.0-beta.8",
    "@openrouter/ai-sdk-provider": "^2.3.0",
    "@tailwindcss/vite": "^4.1.0",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-virtual": "^3.13.0",
    "ai": "^6.0.116",
    "clsx": "^2.1.0",
    "drizzle-orm": "^0.39.0",
    "hono": "^4.7.0",
    "immer": "^10.1.0",
    "mitt": "^3.0.1",
    "nanoid": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.0.0",
    "tailwindcss": "^4.1.0",
    "ulid": "^2.3.0",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.2.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.0",
    "drizzle-kit": "^0.30.0",
    "electron": "^41.0.2",
    "electron-updater": "^6.8.3",
    "tsdown": "^0.21.3",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  }
}
