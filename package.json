{
  "name": "loop",
  "version": "0.1.9",
  "private": true,
  "type": "module",
  "main": "dist-electron/main.cjs",
  "scripts": {
    "dev": "bun run --hot src/server/index.ts",
    "dev:app": "vite dev",
    "dev:electron": "node src/desktop/scripts/dev-electron.mjs",
    "dev:marketing": "next dev src/marketing",
    "build": "vite build",
    "build:electron": "tsdown --config src/desktop/tsdown.config.ts",
    "build:server": "tsdown --config src/server/tsdown.config.ts",
    "build:marketing": "next build src/marketing",
    "lint": "biome check src/",
    "lint:marketing": "biome check src/marketing/app src/marketing/components src/marketing/lib src/marketing/next.config.ts src/marketing/tsconfig.json",
    "lint:fix": "biome check --write src/",
    "typecheck": "tsc --noEmit",
    "typecheck:electron": "tsc -p src/desktop/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack": "bun run build && bun run build:electron && bun run build:server && electron-builder --dir",
    "dist": "bun run build && bun run build:electron && bun run build:server && electron-builder",
    "dist:mac": "bun run build && bun run build:electron && bun run build:server && electron-builder --mac",
    "dist:win": "bun run build && bun run build:electron && bun run build:server && electron-builder --win",
    "dist:linux": "bun run build && bun run build:electron && bun run build:server && electron-builder --linux",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/cohere": "^3.0.25",
    "@ai-sdk/deepinfra": "^2.0.39",
    "@ai-sdk/deepseek": "^2.0.24",
    "@ai-sdk/google": "^3.0.43",
    "@ai-sdk/groq": "^3.0.29",
    "@ai-sdk/mistral": "^3.0.24",
    "@ai-sdk/openai": "^3.0.41",
    "@ai-sdk/openai-compatible": "^2.0.35",
    "@ai-sdk/perplexity": "^3.0.23",
    "@ai-sdk/togetherai": "^2.0.39",
    "@ai-sdk/xai": "^3.0.67",
    "@anthropic-ai/claude-agent-sdk": "^0.2.109",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.42.1",
    "@heroui/react": "^3.0.0-beta.8",
    "@heroui/styles": "^3.0.0-beta.8",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@openai/apps-sdk-ui": "^0.2.1",
    "@opencode-ai/sdk": "^1.14.39",
    "@openrouter/ai-sdk-provider": "^2.3.0",
    "@parcel/watcher": "^2.5.6",
    "@streamdown/math": "^1.0.2",
    "@streamdown/mermaid": "^1.0.2",
    "@tanstack/react-router": "^1.114.0",
    "@tanstack/react-virtual": "^3.13.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "@zip.js/zip.js": "^2.8.26",
    "ai": "^6.0.116",
    "bun-pty": "^0.4.8",
    "clsx": "^2.1.0",
    "codemirror": "^6.0.2",
    "diff": "^8.0.3",
    "dompurify": "^3.3.3",
    "drizzle-orm": "^0.39.0",
    "electron-updater": "^6.8.3",
    "hono": "^4.7.0",
    "immer": "^10.1.0",
    "mitt": "^3.0.1",
    "monaco-editor": "^0.55.1",
    "nanoid": "^5.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "^4.0.2",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.0.0",
    "turndown": "^7.2.2",
    "ulid": "^2.3.0",
    "vscode-material-icons": "^0.1.1",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.2.0",
    "@types/diff": "^8.0.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@types/turndown": "^5.0.6",
    "@vitejs/plugin-react": "^4.4.0",
    "@tailwindcss/vite": "^4.1.0",
    "drizzle-kit": "^0.30.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "next": "^16.2.4",
    "tailwindcss": "^4.1.0",
    "tsdown": "^0.21.3",
    "typescript": "^5.8.0",
    "vite": "^6.3.0",
    "vitest": "^3.1.0"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "sqlite3"
  ]
}
