{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@coding-assistant/shared":       ["packages/shared/index.ts"],
      "@coding-assistant/shared/*":     ["packages/shared/*"],
      "@coding-assistant/core":         ["packages/core/src/index.ts"],
      "@coding-assistant/core/*":       ["packages/core/src/*"]
    }
  },
  "include": [
    "packages/core/src/**/*",
    "packages/shared/**/*",
    "packages/server/**/*",
    "packages/desktop/src/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}
