{
	"compilerOptions": {
		"target": "ES2022",
		"module": "CommonJS",
		"moduleResolution": "node",
		"lib": ["ES2022"],
		"outDir": "../dist-electron",
		"rootDir": ".",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"sourceMap": true,
		"declaration": false,
		"types": ["node"]
	},
	"include": ["./**/*.ts"],
	"exclude": ["scripts"]
}
