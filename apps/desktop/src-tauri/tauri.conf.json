{
  "$schema": "https://raw.githubusercontent.com/nicgirault/tauri-v2-schema/main/schema.json",
  "productName": "Coding Assistant",
  "version": "0.1.0",
  "identifier": "com.coding-assistant.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "bunx vite --port 3000",
    "beforeBuildCommand": "bunx vite build"
  },
  "app": {
    "windows": [
      {
        "title": "Coding Assistant",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "sidecar": true
    }
  }
}
